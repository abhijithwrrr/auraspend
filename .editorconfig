root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 160

[*.{yml,yaml}]
indent_size = 2

[*.xml]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[gradlew.bat]
end_of_line = crlf

[{*.properties,.gitignore}]
indent_size = 0
