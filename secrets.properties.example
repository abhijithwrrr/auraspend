# AuraSpend Secrets Template
# Copy this to secrets.properties and fill in your values.
# secrets.properties is gitignored — never commit real keys.

# Google Drive API OAuth 2.0 Web Client ID (for Google Sign-In)
# Create at https://console.cloud.google.com/apis/credentials
WEB_CLIENT_ID=your_web_client_id_here

# Google Drive API Key (optional, used by some clients)
DRIVE_API_KEY=your_api_key_here
